{
  "name": "mcp-memory-server-functions",
  "version": "1.0.2",
  "description": "Firebase Cloud Functions backend for MCP Memory Server",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "generate-key": "npx ts-node scripts/generateApiKey.ts"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "ts-node": "^10.9.0"
  },
  "private": true
}
